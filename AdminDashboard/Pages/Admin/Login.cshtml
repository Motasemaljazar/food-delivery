@page
@model AdminDashboard.Pages.Admin.LoginModel
@{
    Layout = null;
    var logo = string.IsNullOrWhiteSpace(Model.LogoUrl) ? null : Model.LogoUrl;
    var title = string.IsNullOrWhiteSpace(Model.RestaurantName) ? "لوحة التحكم" : Model.RestaurantName;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>تسجيل الدخول - لوحة التحكم</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet">

  <style>
    :root{
      --gold:#D4AF37;
      --orange:#FF6A00;
      --red:#E11D48;
      --white:#ffffff;
      --ink:#0b1220;
      --ink2:#111827;
    }
    html,body{height:100%;}
    body{
      font-family: 'Cairo', system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      background:
        radial-gradient(900px 450px at 10% 10%, rgba(255,106,0,.22), transparent 60%),
        radial-gradient(800px 500px at 90% 20%, rgba(225,29,72,.20), transparent 60%),
        radial-gradient(700px 500px at 50% 100%, rgba(212,175,55,.18), transparent 60%),
        linear-gradient(180deg, var(--ink), var(--ink2));
      color: var(--white);
    }

    .login-wrap{min-height:100%;}
    .login-card{
      width:100%;
      max-width: 460px;
      border: 1px solid rgba(255,255,255,.12);
      background: rgba(255,255,255,.06);
      backdrop-filter: blur(10px);
      border-radius: 1.25rem;
      overflow: hidden;
      box-shadow: 0 18px 50px rgba(0,0,0,.45);
    }

    .top-bar{
      padding: 22px 22px 16px 22px;
      background:
        linear-gradient(135deg, rgba(212,175,55,.16), rgba(255,106,0,.14) 40%, rgba(225,29,72,.12));
      border-bottom: 1px solid rgba(255,255,255,.10);
    }

    .brand{
      display:flex;
      flex-direction:column;
      align-items:center;
      text-align:center;
      gap: 10px;
    }
    .brand-logo{
      width: 72px;
      height: 72px;
      border-radius: 18px;
      background: rgba(255,255,255,.10);
      border: 1px solid rgba(212,175,55,.45);
      display:flex;
      align-items:center;
      justify-content:center;
      box-shadow: 0 12px 30px rgba(0,0,0,.35);
      overflow:hidden;
    }
    .brand-logo img{width:100%; height:100%; object-fit:cover;}
    .brand-mark{
      width: 34px;
      height: 34px;
      border-radius: 12px;
      background: linear-gradient(135deg, var(--gold), var(--orange), var(--red));
      box-shadow: 0 10px 18px rgba(0,0,0,.25);
    }
    .brand-title{
      font-weight: 800;
      font-size: 1.1rem;
      line-height: 1.2;
      margin: 0;
    }
    .brand-sub{
      margin:0;
      font-size: .85rem;
      color: rgba(255,255,255,.75);
    }

    .card-body{padding: 22px;}

    .form-label{color: rgba(255,255,255,.85);}
    .form-control{
      background: rgba(255,255,255,.08);
      border: 1px solid rgba(255,255,255,.14);
      color: var(--white);
      border-radius: .9rem;
      padding: .75rem .9rem;
    }
    .form-control::placeholder{color: rgba(255,255,255,.55);}
    .form-control:focus{
      box-shadow: 0 0 0 .2rem rgba(212,175,55,.15);
      border-color: rgba(212,175,55,.55);
      background: rgba(255,255,255,.10);
      color: var(--white);
    }

    .btn-login{
      border: 0;
      border-radius: 1rem;
      padding: .75rem 1rem;
      font-weight: 800;
      background: linear-gradient(135deg, var(--red), var(--orange), var(--gold));
      color: var(--white);
      box-shadow: 0 14px 30px rgba(0,0,0,.35);
    }
    .btn-login:hover{filter: brightness(1.05);}

    .hint{color: rgba(255,255,255,.75);}
    .badge-hint{background: rgba(255,255,255,.10); border: 1px solid rgba(255,255,255,.14); color: rgba(255,255,255,.90);}
    .alert{border-radius: 1rem; border: 1px solid rgba(225,29,72,.35); background: rgba(225,29,72,.12); color: #ffd0d8;}

    details summary{cursor:pointer; user-select:none; color: rgba(255,255,255,.75);}
    details summary:hover{color: rgba(255,255,255,.92);}    
  </style>
</head>

<body>
  <div class="container login-wrap d-flex align-items-center justify-content-center py-4">
    <div class="login-card">
      <div class="top-bar">
        <div class="brand">
          <div class="brand-logo">
            @if (logo != null)
            {
              <img src="@logo" alt="Logo" />
            }
            else
            {
              <div class="brand-mark" aria-hidden="true"></div>
            }
          </div>
          <h1 class="brand-title">@title</h1>
          <p class="brand-sub">تسجيل دخول الإدارة</p>
        </div>
      </div>

      <div class="card-body">
        @if (!string.IsNullOrWhiteSpace(Model.Error))
        {
          <div class="alert py-2 mb-3">@Model.Error</div>
        }

        <form method="post" class="vstack gap-3">
          <div>
            <label class="form-label">البريد / اسم المستخدم</label>
            <input class="form-control" name="Email" value="@Model.Email" autocomplete="username" required />
          </div>
          <div>
            <label class="form-label">كلمة المرور</label>
            <input class="form-control" type="password" name="Password" value="@Model.Password" autocomplete="current-password" required />
          </div>
          <button class="btn btn-login w-100" type="submit">دخول</button>
        </form>

        <div class="mt-4">
        </div>
      </div>
    </div>
  </div>
</body>
</html>
