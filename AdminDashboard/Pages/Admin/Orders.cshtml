@page
@model AdminDashboard.Pages.Admin.AdminPageModel

<div class="admin-page-header">
  <div class="page-icon"><i class="bi bi-bag-check"></i></div>
  <div>
    <h1 class="page-title">إدارة الطلبات</h1>
    <p class="page-subtitle">متابعة الطلبات والتعيين والوقت المتوقع</p>
  </div>
</div>

<div class="admin-card">
  <div class="admin-card-header">
    <span>الطلبات الأخيرة</span>
    <div class="d-flex gap-2 align-items-center flex-wrap">
      <select class="form-select form-select-sm" id="bulkDriver" style="min-width:220px"><option value="">اختر سائق...</option></select>
      <button class="btn btn-sm btn-success" id="btnBulkAssign" disabled>تعيين للسائق</button>
      <button class="btn btn-sm btn-warning text-dark" id="btnManualOrder" title="إضافة طلب يدوي من اللوحة"><i class="bi bi-plus-circle me-1"></i>طلب يدوي</button>
      <button class="btn btn-sm btn-danger" id="btnDeleteAll" onclick="deleteAllOrders()">حذف الكل</button>
      <button class="btn btn-sm btn-primary" id="btnRefresh"><i class="bi bi-arrow-clockwise me-1"></i>تحديث</button>
    </div>
  </div>
  <div class="admin-card-body p-0">
  <div class="table-responsive orders-table-responsive">
    <table class="table table-hover table-sm align-middle mb-0 orders-data-table" id="tbl">
      <thead class="table-light"><tr><th class="text-center order-col-chk"><input type="checkbox" id="chkAll" /></th><th class="order-col-id">#</th><th class="order-col-status">الحالة</th><th class="order-col-eta">الوقت</th><th class="order-col-total">المبلغ</th><th class="order-col-fee">الرسوم</th><th class="order-col-km">كم</th><th class="order-col-type">نوع الطلب</th><th class="order-col-customer">الزبون</th><th class="order-col-driver">السائق</th><th class="order-col-actions text-center">إجراءات</th></tr></thead>
      <tbody></tbody>
    </table>
  </div>
  </div>
</div>

<div class="modal fade" id="assignModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header"><h5 class="modal-title">تعيين سائق</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body">
        <input type="hidden" id="orderId" />
        <select class="form-select" id="drivers"></select>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline-secondary" data-bs-dismiss="modal">إلغاء</button>
        <button class="btn btn-primary" id="btnAssign">حفظ</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="etaModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header"><h5 class="modal-title">تحديد الوقت المتوقع للوصول</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body">
        <input type="hidden" id="etaOrderId" />
        <div class="row g-2">
          <div class="col-6">
            <label class="form-label">مدة التجهيز (دقيقة)</label>
            <input class="form-control" type="number" min="0" max="600" id="prepEta" placeholder="مثلاً 15" />
          </div>
          <div class="col-6">
            <label class="form-label">مدة التوصيل (دقيقة)</label>
            <input class="form-control" type="number" min="0" max="600" id="deliveryEta" placeholder="مثلاً 20" />
          </div>
        </div>
        <div class="form-text mt-2">سيظهر للزبون الوقت المتوقع لوصول الطلب (التجهيز + التوصيل).</div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline-secondary" data-bs-dismiss="modal">إلغاء</button>
        <button class="btn btn-primary" id="btnSaveEta">حفظ</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="modalEditOrder" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">تعديل الطلب (بدون وقت)</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="editOrderId" />
        <div class="mb-2 text-muted">الزبون: <span id="editOrderCustomer" class="fw-semibold"></span></div>

        <div class="row g-2">
          <div class="col-md-6">
            <label class="form-label">العنوان</label>
            <input class="form-control" id="editOrderAddress" />
          </div>
          <div class="col-md-3">
            <label class="form-label">خط العرض</label>
            <input class="form-control" id="editOrderLat" />
          </div>
          <div class="col-md-3">
            <label class="form-label">خط الطول</label>
            <input class="form-control" id="editOrderLng" />
          </div>
        </div>

        <div class="row g-2 mt-2">
          <div class="col-md-4">
            <label class="form-label">المسافة (كم)</label>
            <input class="form-control" id="editOrderDistanceKm" readonly placeholder="—" />
          </div>
          <div class="col-md-4">
            <label class="form-label">رسوم التوصيل</label>
            <input class="form-control" type="number" step="0.01" min="0" id="editOrderDeliveryFee" placeholder="0" />
          </div>
        </div>

        <div class="mt-2">
          <label class="form-label">ملاحظة الطلب</label>
          <input class="form-control" id="editOrderNotes" />
        </div>

        <div class="mt-3">
          <label class="form-label mb-2">الأصناف</label>
          <div class="table-responsive">
            <table class="table table-sm table-bordered" id="editOrderItemsTable">
              <thead class="table-light">
                <tr>
                  <th>الصنف</th>
                  <th class="text-center" style="width:100px">الكمية</th>
                  <th class="text-center" style="width:60px">حذف</th>
                </tr>
              </thead>
              <tbody id="editOrderItemsBody"></tbody>
            </table>
          </div>
          <div class="mt-2 d-flex flex-wrap align-items-end gap-2">
            <div class="d-flex align-items-end gap-2 flex-grow-1 flex-wrap">
              <div style="min-width:200px;">
                <label class="form-label small mb-1">إضافة صنف</label>
                <select class="form-select form-select-sm" id="editOrderAddProduct">
                  <option value="">اختر صنفاً...</option>
                </select>
              </div>
              <div style="width:90px;">
                <label class="form-label small mb-1">الكمية</label>
                <input type="number" class="form-control form-control-sm" id="editOrderAddQty" min="1" max="99" value="1" />
              </div>
              <button type="button" class="btn btn-sm btn-outline-primary" id="btnEditOrderAddItem"><i class="bi bi-plus-lg me-1"></i>إضافة صنف</button>
            </div>
          </div>
          <p class="form-text small text-muted mb-0 mt-2">يمكنك تعديل الكمية، حذف صنف، أو إضافة أصناف جديدة من القائمة.</p>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline-secondary" data-bs-dismiss="modal">إلغاء</button>
        <button class="btn btn-warning" onclick="saveEditOrder()">حفظ التعديل</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="modalManualOrder" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>إضافة طلب يدوي</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="row g-2 mb-3">
          <div class="col-md-6">
            <label class="form-label">اسم الزبون <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="manualCustomerName" placeholder="اسم العميل" />
          </div>
          <div class="col-md-6">
            <label class="form-label">رقم الهاتف <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="manualCustomerPhone" placeholder="05xxxxxxxx" dir="ltr" />
          </div>
        </div>
        <div class="row g-2 mb-3">
          <div class="col-md-8">
            <label class="form-label">عنوان التوصيل</label>
            <input type="text" class="form-control" id="manualDeliveryAddress" placeholder="اختياري" />
          </div>
          <div class="col-md-4">
            <label class="form-label">رسوم التوصيل</label>
            <input type="number" class="form-control" id="manualDeliveryFee" value="0" min="0" step="0.01" />
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label">ملاحظة</label>
          <input type="text" class="form-control" id="manualNotes" placeholder="اختياري" />
        </div>
        <div class="mb-2 d-flex justify-content-between align-items-center">
          <label class="form-label mb-0 fw-bold">الأصناف <span class="text-danger">*</span></label>
          <button type="button" class="btn btn-sm btn-outline-primary" id="btnAddManualItem"><i class="bi bi-plus me-1"></i>إضافة صنف</button>
        </div>
        <div class="table-responsive">
          <table class="table table-sm table-bordered">
            <thead class="table-light">
              <tr>
                <th style="width:55%">الصنف</th>
                <th class="text-center" style="width:25%">الكمية</th>
                <th class="text-center" style="width:20%">إجراء</th>
              </tr>
            </thead>
            <tbody id="manualOrderItemsBody"></tbody>
          </table>
        </div>
        <p class="form-text small text-muted mb-0">يجب إضافة صنف واحد على الأقل. يتم إنشاء الزبون تلقائياً إن لم يكن مسجلاً بالرقم.</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">إلغاء</button>
        <button type="button" class="btn btn-warning text-dark" id="btnSubmitManualOrder"><i class="bi bi-check2 me-1"></i>إنشاء الطلب</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="modalOrderActions" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-sm">
    <div class="modal-content">
      <div class="modal-header py-2">
        <h6 class="modal-title"><i class="bi bi-list-ul me-2"></i>إجراءات الطلب</h6>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-2" id="modalOrderActionsBody">
        <!-- تُملأ ديناميكياً عند فتح النافذة -->
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="modalViewOrder" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content border-0" style="border-radius:16px; overflow:hidden;">
      <div class="modal-header text-white border-0" style="background: linear-gradient(135deg, #b8860b 0%, #daa520 50%, #b8860b 100%); padding: 1.5rem 1.5rem 1rem;">
        <div class="d-flex align-items-center gap-3">
          <div style="background:rgba(255,255,255,0.2); border-radius:50%; width:48px; height:48px; display:flex; align-items:center; justify-content:center;">
            <i class="bi bi-receipt fs-5"></i>
          </div>
          <div>
            <h5 class="modal-title mb-0 fw-bold" id="viewOrderTitle">تفاصيل الطلب</h5>
            <small id="viewOrderDate" class="opacity-75"></small>
          </div>
        </div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-0" id="viewOrderBody" style="background:#f8f9fa;">
        <div class="text-center py-5"><div class="spinner-border" style="color:#daa520;"></div></div>
      </div>
      <div class="modal-footer border-0" style="background:#f8f9fa;">
        <button class="btn btn-outline-secondary" data-bs-dismiss="modal">إغلاق</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
const tblBody = document.querySelector('#tbl tbody');
const assignModal = new bootstrap.Modal(document.getElementById('assignModal'));
const driversSelect = document.getElementById('drivers');
const bulkDriverSelect = document.getElementById('bulkDriver');
const btnBulkAssign = document.getElementById('btnBulkAssign');
const chkAll = document.getElementById('chkAll');
const selectedIds = new Set();
let _ordersList = [];
let _orderActionsModal = null;

async function loadDrivers(){
  const res = await fetch('/api/admin/drivers');
  if(!res.ok) return [];
  return await res.json();
}

const driverStatusTxt = (st)=> ['متاح','مشغول','غير متاح'][st] || '';
async function fillDrivers(selectEl){
  const drivers = await loadDrivers();
  selectEl.innerHTML = ['<option value="">اختر سائق</option>'].concat(drivers.map(d=>`<option value="${d.id}">#${d.id} - ${d.name} (${driverStatusTxt(d.status)})</option>`)).join('');
}

const statusName = (s)=>['طلب جديد','مؤكد','قيد التجهيز','جاهز للاستلام','مع السائق','تم التوصيل','تم الإلغاء'][s] || s;
const printedOrders = new Set(JSON.parse(localStorage.getItem('printedOrders') || '[]'));
function formatAmount(v){ const n = Number(v); if(isNaN(n)) return '—'; return String(Math.floor(n)); }

async function load(){
  const res = await fetch('/api/admin/orders');
  if(!res.ok){ tblBody.innerHTML='<tr><td colspan="11">فشل تحميل الطلبات</td></tr>'; return; }
  let list = [];
  try { list = await res.json(); }
  catch(e){
    console.error('orders json parse failed', e);
    tblBody.innerHTML='<tr><td colspan="11">تعذر قراءة بيانات الطلبات (قد تكون الجلسة انتهت). أعد تسجيل الدخول ثم حدّث الصفحة.</td></tr>';
    return;
  }
  const deliveryFeeText = (o)=> (o.deliveryFee != null ? formatAmount(o.deliveryFee) : '—');
  const distanceText = (o)=> (o.deliveryDistanceKm != null && o.deliveryDistanceKm > 0 ? formatAmount(o.deliveryDistanceKm) : '—');
  const totalText = (o)=> { const n = Number(o.total); return isNaN(n) ? '—' : formatAmount(n); };
  const etaText = (o)=>{
    const p = o.prepEtaMinutes ?? 0;
    const d = o.deliveryEtaMinutes ?? 0;
    const total = p + d;
    if(total>0) return `<span class="badge bg-success">${total} </span>`;
    const approx = o.approxTravelEtaMinutes ?? 0;
    if(approx>0) return `<span class="badge bg-outline-secondary" style="border:1px solid #6c757d; color:#6c757d;">~${approx} </span>`;
    return '<span class="text-muted"></span>';
  };
  const mapBtn = (o)=>{
    const lat = (typeof o.deliveryLat === 'number') ? o.deliveryLat : 0;
    const lng = (typeof o.deliveryLng === 'number') ? o.deliveryLng : 0;
    const disabled = (!lat || !lng) ? 'disabled' : '';
    return `<button class="btn btn-outline-info" ${disabled} onclick="openMap(${lat}, ${lng})">خريطة</button>`;
  };
  // تحديد نوع الطلب من orderType فقط (لا استنتاج من الإحداثيات)
  const orderTypeLabel = (o)=>{
    const typ = (o.orderType || 'delivery').toLowerCase();
    if (typ === 'pickup') return '<span class="badge bg-info">استلام من الفرع</span>';
    if (typ === 'dine-in' || typ === 'dinein') return '<span class="badge bg-secondary">في المطعم</span>';
    return '<span class="badge bg-primary">توصيل</span>';
  };
  _ordersList = list;
  tblBody.innerHTML = list.map(o=>`<tr>
    <td class="order-mobile-chk" data-label="تحديد"><input class="chkRow" type="checkbox" data-id="${o.id}" ${selectedIds.has(o.id)?'checked':''} /></td>
    <td data-label="الترقيم">${o.id}</td>
    <td data-label="الحالة">
      <span class="badge bg-secondary">${statusName(o.currentStatus)}</span>
      ${printedOrders.has(o.id) ? ' <span class="badge bg-success" title="تمت الطباعة"><i class="bi bi-check-circle-fill"></i> مطبوع</span>' : ''}
      ${o.wasEditedByCustomer ? ' <span class="badge bg-warning text-dark">تم تعديل الطلب من قبل الزبون</span>' : ''}
      ${o.wasEditedByAdmin ? ' <span class="badge bg-info text-dark">تم تعديل الطلب من قبل الإدارة</span>' : ''}
      ${(o.currentStatus===6 && o.cancelLabel) ? ` <span class="badge bg-danger">${o.cancelLabel}</span>` : ''}
    </td>
    <td data-label="الوقت">${etaText(o)}</td>
    <td class="order-col-total" data-label="المبلغ">${totalText(o)}</td>
    <td class="order-col-fee" data-label="الرسوم">${deliveryFeeText(o)}</td>
    <td class="order-col-km" data-label="كم">${distanceText(o)}</td>
    <td data-label="نوع الطلب">${orderTypeLabel(o)}</td>
    <td data-label="الزبون">
      <div class="fw-semibold">${o.customerName ?? ('#'+o.customerId)}</div>
      <div class="text-muted" style="font-size:12px">${o.customerPhone ?? ''}</div>
    </td>
    <td data-label="السائق">${o.driverId ?? '-'}</td>
    <td class="text-center order-mobile-actions order-actions-cell" data-label="إجراءات">
      <button class="btn btn-sm btn-outline-primary" type="button" onclick="openOrderActionsPopup(${o.id})" title="إجراءات">
        <i class="bi bi-three-dots-vertical me-1"></i>إجراءات
      </button>
    </td>
  </tr>`).join('');

  document.querySelectorAll('.chkRow').forEach(el=>{
    el.addEventListener('change', (e)=>{
      const id = parseInt(e.target.getAttribute('data-id'));
      if(e.target.checked) selectedIds.add(id); else selectedIds.delete(id);
      btnBulkAssign.disabled = selectedIds.size===0 || !bulkDriverSelect.value;
    });
  });

  chkAll.checked = list.length>0 && [...selectedIds].length===list.length;
  btnBulkAssign.disabled = selectedIds.size===0 || !bulkDriverSelect.value;
}

async function cancelOrder(orderId){
  if(!confirm('هل أنت متأكد من إلغاء الطلب؟')) return;
  try{
    const res = await fetch(`/api/admin/order/${orderId}/cancel`, { method:'POST' });
    if(!res.ok){
      let msg = 'فشل إلغاء الطلب';
      try{ const j = await res.json(); if(j && j.message) msg = j.message; }catch(_){ }
      alert(msg);
      return;
    }
    await load();
    if(window.adminToast) window.adminToast('تم الإلغاء', `تم إلغاء الطلب #${orderId}`, 'warn');
  }catch(e){
    console.error(e);
    alert('حدث خطأ أثناء الإلغاء');
  }
}

async function deleteOrder(orderId){
  if(!confirm('⚠️ هل أنت متأكد من حذف الطلب نهائياً؟\n\nسيتم حذف الطلب من التقارير والإيرادات وجميع البيانات المتعلقة به.\n\nهذا الإجراء لا يمكن التراجع عنه!')) return;
  try{
    const res = await fetch(`/api/admin/order/${orderId}/delete`, { method:'DELETE' });
    if(!res.ok){
      let msg = 'فشل حذف الطلب';
      try{ const j = await res.json(); if(j && j.message) msg = j.message; }catch(_){ }
      alert(msg);
      return;
    }
    await load();
    if(window.adminToast) window.adminToast('تم الحذف', `تم حذف الطلب #${orderId} نهائياً`, 'warn');
  }catch(e){
    console.error(e);
    alert('حدث خطأ أثناء الحذف');
  }
}

async function deleteAllOrders(){
  if(!confirm('⚠️⚠️⚠️ تحذير شديد الخطورة ⚠️⚠️⚠️\n\nهل أنت متأكد تماماً من حذف جميع الطلبات من قاعدة البيانات؟\n\nسيتم حذف كافة الطلبات (الحالية + السابقة) من التقارير والإيرادات وجميع البيانات المتعلقة بها.\n\nهذا الإجراء لا يمكن التراجع عنه إطلاقاً!\n\nاضغط "موافق" فقط إذا كنت متأكداً 100%.')) return;
  if(!confirm('تأكيد نهائي: هل تريد حقاً حذف جميع الطلبات بشكل نهائي؟')) return;
  try{
    const res = await fetch('/api/admin/orders/delete-all', { method:'DELETE' });
    if(!res.ok){
      let msg = 'فشل حذف الطلبات';
      try{ const j = await res.json(); if(j && j.message) msg = j.message; }catch(_){ }
      alert(msg);
      return;
    }
    const result = await res.json();
    await load();
    if(window.adminToast) window.adminToast('تم الحذف', `تم حذف ${result.deletedCount || 0} طلب/طلبات نهائياً`, 'warn');
  }catch(e){
    console.error(e);
    alert('حدث خطأ أثناء الحذف');
  }
}

let editOrderModal = null;
let _editOrderItems = [];
let _editOrderProducts = [];
let _editOrderVariantsByProduct = {};
let _editOrderAddonsByProduct = {};

function renderEditOrderItems(items){
  const tbody = document.getElementById('editOrderItemsBody');
  tbody.innerHTML = items.map((it, idx)=>{
    const prodName = it.productNameSnapshot || 'صنف #' + it.productId;
    const unitPrice = (it.unitPriceSnapshot != null) ? Number(it.unitPriceSnapshot).toFixed(2) : '0.00';
    const productId = it.productId;
    const vars = _editOrderVariantsByProduct[productId] || [];
    const adds = _editOrderAddonsByProduct[productId] || [];

    let parsed = null;
    if (typeof it.optionsSnapshot === 'string' && it.optionsSnapshot.trim().startsWith('{')) {
      try { parsed = JSON.parse(it.optionsSnapshot); } catch(_) {}
    }
    const selectedVariantId = parsed && parsed.variantId ? parsed.variantId : null;
    const selectedAddonIds = parsed && Array.isArray(parsed.addonIds) ? parsed.addonIds : [];

    let optionsHtml = '';
    if (vars.length || adds.length) {
      optionsHtml += '<div class="mt-1 small text-muted">الخيارات:</div>';
      if (vars.length) {
        optionsHtml += '<div class="mb-1">';
        vars.forEach(v => {
          const id = v.id;
          const name = (v.name || '').toString();
          const delta = Number(v.priceDelta || 0);
          const label = delta === 0 ? name : `${name} (+${delta.toFixed(0)})`;
          const inputId = `edit-var-${idx}-${id}`;
          const checked = selectedVariantId === id ? 'checked' : '';
          optionsHtml += `<div class="form-check form-check-inline mb-0">
            <input class="form-check-input edit-item-variant" type="radio" name="editVar_${idx}" id="${inputId}" value="${id}" ${checked}>
            <label class="form-check-label small" for="${inputId}">${label}</label>
          </div>`;
        });
        optionsHtml += '</div>';
      }
      if (adds.length) {
        optionsHtml += '<div>';
        adds.forEach(a => {
          const id = a.id;
          const name = (a.name || '').toString();
          const price = Number(a.price || 0);
          const inputId = `edit-add-${idx}-${id}`;
          const checked = selectedAddonIds.includes(id) ? 'checked' : '';
          optionsHtml += `<div class="form-check form-check-inline mb-0">
            <input class="form-check-input edit-item-addon" type="checkbox" id="${inputId}" value="${id}" ${checked}>
            <label class="form-check-label small" for="${inputId}">${name}${price ? ` (+${price.toFixed(0)})` : ''}</label>
          </div>`;
        });
        optionsHtml += '</div>';
      }
    }

    return `<tr data-idx="${idx}">
      <td>
        <div>
          <div>${prodName}</div>
          <div class="text-muted small">سعر الوحدة: ${unitPrice}</div>
          ${optionsHtml}
        </div>
      </td>
      <td class="text-center"><input class="form-control form-control-sm edit-item-qty" data-idx="${idx}" type="number" min="1" max="99" value="${it.quantity || 1}" style="width:80px; margin:0 auto;" /></td>
      <td class="text-center"><button type="button" class="btn btn-sm btn-outline-danger py-0 px-1 edit-item-remove" data-idx="${idx}" title="حذف الصنف"><i class="bi bi-trash"></i></button></td>
    </tr>`;
  }).join('');
  tbody.querySelectorAll('.edit-item-remove').forEach(btn=>{
    btn.addEventListener('click', function(){
      const idx = parseInt(this.getAttribute('data-idx'), 10);
      if(isNaN(idx) || idx < 0 || idx >= _editOrderItems.length) return;
      _editOrderItems.splice(idx, 1);
      renderEditOrderItems(_editOrderItems);
    });
  });
}

async function loadEditOrderProducts(){
  if(_editOrderProducts.length > 0) return _editOrderProducts;
  const res = await fetch('/api/admin/menu');
  if(!res.ok) return [];
  const data = await res.json();
  _editOrderProducts = (data.products || []).filter(p => p.isActive !== false).map(p => ({ id: p.id, name: p.name || ('صنف #' + p.id), price: p.price || 0 }));
  _editOrderVariantsByProduct = {};
  (data.variants || []).forEach(v => {
    if(v.isActive === false) return;
    const pid = v.productId;
    if(!_editOrderVariantsByProduct[pid]) _editOrderVariantsByProduct[pid] = [];
    _editOrderVariantsByProduct[pid].push(v);
  });
  _editOrderAddonsByProduct = {};
  (data.addons || []).forEach(a => {
    if(a.isActive === false) return;
    const pid = a.productId;
    if(!_editOrderAddonsByProduct[pid]) _editOrderAddonsByProduct[pid] = [];
    _editOrderAddonsByProduct[pid].push(a);
  });
  return _editOrderProducts;
}

function fillEditOrderAddProductSelect(){
  const sel = document.getElementById('editOrderAddProduct');
  sel.innerHTML = '<option value="">اختر صنفاً...</option>' + _editOrderProducts.map(p => {
