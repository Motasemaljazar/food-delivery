window.openPrint = async (orderId)=>{
  if (typeof window.printOrder !== 'function') {
    if (window.adminToast) window.adminToast('الطباعة من الويب معطلة', 'الطباعة تتم فقط من تطبيق الويندوز مع الطابعات المختارة فيه.', 'warn');
    else alert('الطباعة تتم فقط من تطبيق الويندوز مع الطابعات المختارة فيه.');
    return;
  }
  try {
    const res = await fetch(`/api/admin/order/${orderId}`, { credentials: 'same-origin' });
    if (!res.ok) { alert('تعذر تحميل تفاصيل الطلب'); return; }
    const order = await res.json();
    const orderTime = order.createdAtUtc ? new Date(order.createdAtUtc).toISOString() : new Date().toISOString();
    const orderData = {
      orderId: String(order.id),
      customerName: order.customerName || 'عميل',
      customerPhone: order.customerPhone || '',
      items: (order.items || []).map(i => ({
        productName: i.productNameSnapshot || '',
        quantity: i.quantity || 1,
        price: Number(i.unitPriceSnapshot) || 0,
        category: i.categoryName || undefined,
        categoryId: i.categoryId != null ? i.categoryId : undefined
      })),
      totalAmount: Number(order.total) || 0,
      deliveryAddress: order.deliveryAddress || undefined,
      notes: order.notes || undefined,
      orderTime: orderTime,
      paymentMethod: order.paymentMethod || 'نقدي',
      orderType: order.orderType || 'delivery'
    };
    window.__topchefPrintResult = function(result) {
      if (result && typeof result.message === 'string') {
        if (result.success) {
          printedOrders.add(orderId);
          localStorage.setItem('printedOrders', JSON.stringify([...printedOrders]));
          const el = document.querySelector('a.link-print-order[data-print-order-id="' + orderId + '"]');
          if (el) el.innerHTML = '<i class="bi bi-printer me-2"></i>تمت الطباعة';
          if (window.adminToast) window.adminToast('تمت الطباعة', result.message, 'success');
          else {
            const toast = document.createElement('div');
            toast.className = 'position-fixed bottom-0 start-50 translate-middle-x mb-3 px-4 py-2 rounded bg-success text-white';
            toast.textContent = result.message;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
          }
        } else {
          alert(result.message);
        }
      }
      window.__topchefPrintResult = null;
    };
    window.printOrder(orderData);
  } catch (e) {
    console.error(e);
    alert('حدث خطأ أثناء إعداد الطباعة');
  }
};

