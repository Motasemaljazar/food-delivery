    return `<option value="${p.id}">${name} — ${Number(p.price || 0).toFixed(0)} ل.س</option>`;
  }).join('');
}

async function openEditOrder(orderId){
  try{
    const res = await fetch(`/api/admin/order/${orderId}`);
    if(!res.ok){ alert('تعذر تحميل بيانات الطلب'); return; }
    const o = await res.json();
    document.getElementById('editOrderId').value = o.id;
    document.getElementById('editOrderCustomer').textContent = (o.customerName || ('#'+o.customerId));
    document.getElementById('editOrderNotes').value = o.notes || '';
    document.getElementById('editOrderAddress').value = o.deliveryAddress || '';
    document.getElementById('editOrderLat').value = (typeof o.deliveryLat === 'number') ? o.deliveryLat : '';
    document.getElementById('editOrderLng').value = (typeof o.deliveryLng === 'number') ? o.deliveryLng : '';
    document.getElementById('editOrderDistanceKm').value = (o.deliveryDistanceKm != null && o.deliveryDistanceKm > 0) ? Number(o.deliveryDistanceKm).toFixed(2) : '—';
    document.getElementById('editOrderDeliveryFee').value = (o.deliveryFee != null) ? Number(o.deliveryFee).toFixed(2) : '';
    await loadEditOrderProducts();
    _editOrderItems = (o.items || []).map(i => ({
      productId: i.productId,
      quantity: i.quantity || 1,
      optionsSnapshot: i.optionsSnapshot ?? null,
      productNameSnapshot: i.productNameSnapshot,
      unitPriceSnapshot: i.unitPriceSnapshot
    }));
    renderEditOrderItems(_editOrderItems);
    fillEditOrderAddProductSelect();
    document.getElementById('editOrderAddProduct').value = '';
    document.getElementById('editOrderAddQty').value = '1';
    if(!editOrderModal) editOrderModal = new bootstrap.Modal(document.getElementById('modalEditOrder'));
    editOrderModal.show();
  }catch(e){
    console.error(e);
    alert('حدث خطأ أثناء فتح التعديل');
  }
}

async function saveEditOrder(){
  const id = parseInt(document.getElementById('editOrderId').value);
  const items = [];
  for (let i = 0; i < _editOrderItems.length; i++) {
    const it = _editOrderItems[i];
    const row = document.querySelector(`#editOrderItemsBody tr[data-idx="${i}"]`);
    let qty = it.quantity;
    const input = document.querySelector('#editOrderItemsBody .edit-item-qty[data-idx="' + i + '"]');
    if (input) {
      const v = parseInt(input.value, 10);
      if (!isNaN(v) && v >= 1 && v <= 99) qty = v;
    }
    let optionsSnapshot = it.optionsSnapshot;
    if (row) {
      const varInput = row.querySelector('.edit-item-variant:checked');
      const addonInputs = row.querySelectorAll('.edit-item-addon:checked');
      const variantId = varInput ? parseInt(varInput.value, 10) : null;
      const addonIds = Array.from(addonInputs)
        .map(el => parseInt(el.value, 10))
        .filter(v => !isNaN(v));
      const optObj = {};
      if (variantId && !isNaN(variantId)) optObj.variantId = variantId;
      if (addonIds.length) optObj.addonIds = addonIds;
      optionsSnapshot = Object.keys(optObj).length ? JSON.stringify(optObj) : null;
      _editOrderItems[i].optionsSnapshot = optionsSnapshot;
    }
    items.push({ productId: it.productId, quantity: qty, optionsSnapshot });
  }
  const deliveryFeeVal = document.getElementById('editOrderDeliveryFee').value.trim();
  const payload = {
    items,
    notes: document.getElementById('editOrderNotes').value,
    deliveryAddress: document.getElementById('editOrderAddress').value,
    deliveryLat: document.getElementById('editOrderLat').value ? Number(document.getElementById('editOrderLat').value) : null,
    deliveryLng: document.getElementById('editOrderLng').value ? Number(document.getElementById('editOrderLng').value) : null,
    deliveryFee: deliveryFeeVal !== '' && isFinite(Number(deliveryFeeVal)) ? Number(deliveryFeeVal) : null,
  };
  const res = await fetch(`/api/admin/order/${id}/edit`, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(payload) });
  if(!res.ok){
    let msg='فشل حفظ التعديل';
    try{ const j = await res.json(); if(j && j.message) msg=j.message; }catch(_){ }
    alert(msg);
    return;
  }
  editOrderModal.hide();
  await load();
  if(window.adminToast) window.adminToast('تم الحفظ', `تم تعديل الطلب #${id}`, 'info');
}

