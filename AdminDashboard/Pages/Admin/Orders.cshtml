let viewOrderModal = null;

window.openViewOrder = async (orderId) => {
  if (!viewOrderModal) viewOrderModal = new bootstrap.Modal(document.getElementById('modalViewOrder'));
  document.getElementById('viewOrderTitle').textContent = `تفاصيل الطلب #${orderId}`;
  document.getElementById('viewOrderDate').textContent = '';
  document.getElementById('viewOrderBody').innerHTML = '<div class="text-center py-5"><div class="spinner-border" style="color:#daa520;"></div></div>';
  viewOrderModal.show();
  try {
    const res = await fetch(`/api/admin/order/${orderId}`, { credentials: 'same-origin' });
    if (!res.ok) { document.getElementById('viewOrderBody').innerHTML = '<div class="text-center py-5 text-danger"><i class="bi bi-exclamation-circle fs-3"></i><p class="mt-2">تعذر تحميل تفاصيل الطلب</p></div>'; return; }
    const o = await res.json();
    const statusColors = ['primary','success','warning','info','secondary','success','danger'];
    const statusNames = ['طلب جديد','مؤكد','قيد التجهيز','جاهز للاستلام','مع السائق','تم التوصيل','تم الإلغاء'];
    const st = o.currentStatus || 0;
    const statusColor = statusColors[st] || 'secondary';
    const statusLabel = statusNames[st] || st;
    const orderDate = o.createdAtUtc ? new Date(o.createdAtUtc) : null;
    const dateStr = orderDate ? orderDate.toLocaleString('ar-SA', { year:'numeric', month:'long', day:'numeric', hour:'2-digit', minute:'2-digit' }) : '';
    document.getElementById('viewOrderDate').textContent = dateStr;
    const subtotal = (o.items || []).reduce((s, i) => s + (Number(i.unitPriceSnapshot) * (i.quantity || 1)), 0);
    const deliveryFee = o.deliveryFee != null ? Number(o.deliveryFee) : 0;
    const total = Number(o.total) || 0;
    const orderTypeT = (o.orderType || 'delivery').toLowerCase();
    const orderTypeBadgeClass = orderTypeT === 'pickup' ? 'bg-info' : (orderTypeT === 'dine-in' || orderTypeT === 'dinein') ? 'bg-secondary' : 'bg-primary';
    const orderTypeText = orderTypeT === 'pickup' ? 'استلام من الفرع' : (orderTypeT === 'dine-in' || orderTypeT === 'dinein') ? 'في المطعم' : 'توصيل';
    const itemsHtml = (o.items || []).map(i => {
      const opts = i.optionsSnapshot;
      let optsStr = '';
      if (opts && Array.isArray(opts) && opts.length > 0) {
        optsStr = `<div class="text-muted small mt-1">${opts.map(op => (op.name || '') + (op.value ? ': ' + op.value : '')).join(' • ')}</div>`;
      }
      const lineTotal = formatAmount(Number(i.unitPriceSnapshot) * (i.quantity || 1));
      return `<div class="d-flex align-items-start justify-content-between py-2 border-bottom">
        <div class="flex-grow-1">
          <div class="fw-semibold">${i.productNameSnapshot || 'صنف'}</div>
          ${optsStr}
          <div class="text-muted small">${(i.quantity || 1)} × ${formatAmount(Number(i.unitPriceSnapshot))}</div>
        </div>
        <div class="fw-bold ms-3 text-end" style="min-width:70px;">${lineTotal}</div>
      </div>`;
    }).join('');
    document.getElementById('viewOrderBody').innerHTML = `
      <div class="p-3 pb-0">
        <div class="d-flex flex-wrap gap-2 mb-3">
          <span class="badge bg-${statusColor} fs-6 px-3 py-2">${statusLabel}</span>
          ${o.wasEditedByCustomer ? '<span class="badge bg-warning text-dark fs-6 px-3 py-2">تم تعديل الطلب من الزبون</span>' : ''}
        </div>
        <div class="row g-3 mb-3">
          <div class="col-sm-6">
            <div class="rounded-3 p-3 h-100" style="background:white; border:1px solid #e9ecef;">
              <div class="text-muted small mb-2"><i class="bi bi-person-circle me-1"></i>معلومات الزبون</div>
              <div class="fw-bold fs-6">${o.customerName || ('زبون #' + o.customerId)}</div>
              ${o.customerPhone ? `<div class="mt-1"><a href="tel:${o.customerPhone}" class="text-decoration-none"><i class="bi bi-telephone me-1" style="color:#daa520;"></i>${o.customerPhone}</a></div>` : ''}
            </div>
          </div>
          <div class="col-sm-6">
            <div class="rounded-3 p-3 h-100" style="background:white; border:1px solid #e9ecef;">
              <div class="text-muted small mb-2"><i class="bi bi-truck me-1"></i>معلومات التوصيل</div>
              <div class="mb-2"><span class="badge ${orderTypeBadgeClass}">${orderTypeText}</span></div>
              ${o.deliveryAddress ? `<div class="fw-semibold"><i class="bi bi-geo-alt me-1" style="color:#daa520;"></i>${o.deliveryAddress}</div>` : '<div class="text-muted">لا يوجد عنوان</div>'}
              ${o.deliveryDistanceKm ? `<div class="small text-muted mt-1"><i class="bi bi-arrows-move me-1"></i>${formatAmount(o.deliveryDistanceKm)} كم</div>` : ''}
              ${o.driverId ? `<div class="small mt-1"><i class="bi bi-person-badge me-1" style="color:#daa520;"></i>السائق: ${o.driverId}</div>` : ''}
            </div>
          </div>
        </div>
        ${o.notes ? `<div class="rounded-3 p-3 mb-3" style="background:#fff8e1; border:1px solid #ffe082;"><i class="bi bi-sticky me-2" style="color:#daa520;"></i><span class="fw-semibold">ملاحظة: </span>${o.notes}</div>` : ''}
      </div>
      <div class="px-3">
        <div class="rounded-3 p-3 mb-3" style="background:white; border:1px solid #e9ecef;">
          <div class="text-muted small mb-2 fw-bold"><i class="bi bi-bag me-1"></i>الأصناف المطلوبة</div>
          ${itemsHtml}
        </div>
        <div class="rounded-3 p-3 mb-3" style="background:white; border:1px solid #e9ecef;">
          <div class="d-flex justify-content-between py-1"><span class="text-muted">المجموع الفرعي</span><span>${formatAmount(subtotal)}</span></div>
          ${deliveryFee > 0 ? `<div class="d-flex justify-content-between py-1"><span class="text-muted">رسوم التوصيل</span><span>${formatAmount(deliveryFee)}</span></div>` : ''}
          <div class="d-flex justify-content-between py-2 border-top mt-1">
            <span class="fw-bold fs-6">الإجمالي</span>
            <span class="fw-bold fs-5" style="color:#b8860b;">${formatAmount(total)}</span>
          </div>
        </div>
        ${o.history && o.history.length > 0 ? `
        <div class="rounded-3 p-3 mb-3" style="background:white; border:1px solid #e9ecef;">
          <div class="text-muted small mb-3 fw-bold"><i class="bi bi-clock-history me-1"></i>سجل الحالات</div>
          <div style="position:relative; padding-right:20px;">
            <div style="position:absolute; right:7px; top:0; bottom:0; width:2px; background:#ffe082; border-radius:2px;"></div>
            ${o.history.map((h, idx) => {
              const hColors = ['primary','success','warning','info','secondary','success','danger'];
              const hNames = ['طلب جديد','مؤكد','قيد التجهيز','جاهز للاستلام','مع السائق','تم التوصيل','تم الإلغاء'];
              const byType = ['','زبون','مطعم','سائق','نظام'];
              const hDate = h.changedAtUtc ? new Date(h.changedAtUtc).toLocaleString('ar-SA', {month:'short', day:'numeric', hour:'2-digit', minute:'2-digit'}) : '';
              const isLast = idx === o.history.length - 1;
              return `<div class="d-flex align-items-start gap-2 mb-3" style="position:relative;">
                <div style="position:absolute; right:-20px; top:4px; width:14px; height:14px; border-radius:50%; background:${isLast ? '#daa520' : '#fff'}; border:2px solid #daa520; z-index:1;"></div>
                <div class="flex-grow-1 rounded-2 p-2" style="background:${isLast ? '#fff8e1' : '#f8f9fa'}; border:1px solid ${isLast ? '#ffe082' : '#e9ecef'};">
                  <div class="d-flex justify-content-between align-items-center">
                    <span class="badge bg-${hColors[h.status] || 'secondary'}">${hNames[h.status] || h.status}</span>
                    <small class="text-muted">${hDate}</small>
                  </div>
                  ${h.changedByType ? `<div class="small text-muted mt-1"><i class="bi bi-person me-1"></i>${byType[h.changedByType] || ''}</div>` : ''}
                  ${h.comment ? `<div class="small mt-1" style="color:#555;">${h.comment}</div>` : ''}
                </div>
              </div>`;
            }).join('')}
          </div>
        </div>` : ''}
      </div>`;
  } catch (e) {
    console.error(e);
    document.getElementById('viewOrderBody').innerHTML = '<div class="text-center py-5 text-danger"><i class="bi bi-exclamation-circle fs-3"></i><p class="mt-2">حدث خطأ أثناء تحميل البيانات</p></div>';
  }
};

</script>
