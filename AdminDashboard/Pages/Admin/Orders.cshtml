// ——— طلب يدوي ———
let manualOrderProducts = [];
let manualOrderVariantsByProduct = {};
let manualOrderAddonsByProduct = {};
/** عرض -> المنتج المرتبط (لخيارات النوع/الإضافات) */
let manualOrderOfferPrimaryProduct = {};
let manualOrderModal = null;

async function loadManualOrderProducts(){
  const res = await fetch('/api/admin/menu');
  if(!res.ok) return [];
  const data = await res.json();
  const prods = (data.products || []).filter(p => p.isActive !== false).map(p => ({ id: p.id, name: p.name || ('صنف #' + p.id), price: p.price || 0 }));
  manualOrderOfferPrimaryProduct = {};
  const offerList = (data.offers || []).map(o => {
    const price = (o.priceAfter != null ? o.priceAfter : o.priceBefore) != null ? (Number(o.priceAfter) || Number(o.priceBefore) || 0) : 0;
    if(o.primaryProductId) manualOrderOfferPrimaryProduct[Number(o.id)] = o.primaryProductId;
    return { id: -Number(o.id), name: (o.title || 'عرض #' + o.id) + ' (عرض)', price };
  });
  manualOrderProducts = [...prods, ...offerList];
  manualOrderVariantsByProduct = {};
  (data.variants || []).forEach(v => {
    if(v.isActive === false) return;
    const pid = v.productId;
    if(!manualOrderVariantsByProduct[pid]) manualOrderVariantsByProduct[pid] = [];
    manualOrderVariantsByProduct[pid].push(v);
  });
  manualOrderAddonsByProduct = {};
  (data.addons || []).forEach(a => {
    if(a.isActive === false) return;
    const pid = a.productId;
    if(!manualOrderAddonsByProduct[pid]) manualOrderAddonsByProduct[pid] = [];
    manualOrderAddonsByProduct[pid].push(a);
  });
  return manualOrderProducts;
}

function renderManualOrderRow(index, products, selectedId, qty){
  const opts = products.map(p => `<option value="${p.id}" ${p.id === selectedId ? 'selected' : ''}>${p.name} — ${Number(p.price).toFixed(0)} ل.س</option>`).join('');
  return `<tr data-idx="${index}">
    <td>
      <select class="form-select form-select-sm manual-item-product">${opts ? '<option value="">اختر صنفاً</option>' + opts : '<option value="">لا توجد أصناف</option>'}</select>
      <div class="mt-1 small text-muted manual-item-options"></div>
    </td>
    <td class="text-center"><input type="number" class="form-control form-control-sm manual-item-qty" min="1" max="99" value="${qty || 1}" style="width:70px;margin:0 auto;" /></td>
    <td class="text-center"><button type="button" class="btn btn-sm btn-outline-danger btn-remove-manual-item" title="حذف"><i class="bi bi-trash"></i></button></td>
  </tr>`;
}

function renderManualOptionsForRow(tr){
  const prodSelect = tr.querySelector('.manual-item-product');
  const container = tr.querySelector('.manual-item-options');
  if(!prodSelect || !container) return;
  const productId = parseInt(prodSelect.value, 10);
  if(!productId){
    container.innerHTML = '';
    return;
  }
  let vars = [], adds = [];
  if(productId < 0){
    const offerId = -productId;
    const primaryProductId = manualOrderOfferPrimaryProduct[offerId];
    if(primaryProductId){
      vars = manualOrderVariantsByProduct[primaryProductId] || [];
      adds = manualOrderAddonsByProduct[primaryProductId] || [];
    }
    if(vars.length === 0 && adds.length === 0){
      container.innerHTML = '<span class="text-muted">عرض — لا أنواع أو إضافات</span>';
      return;
    }
  } else {
    vars = manualOrderVariantsByProduct[productId] || [];
    adds = manualOrderAddonsByProduct[productId] || [];
  }
  if(vars.length === 0 && adds.length === 0){
    container.innerHTML = '<span class="text-muted">لا توجد أنواع أو إضافات لهذا الصنف.</span>';
    return;
  }
  const idx = tr.getAttribute('data-idx') || '0';
  let html = '';
  if(vars.length){
    html += '<div class="mb-1"><span class="d-block mb-1">النوع:</span>';
    vars.forEach(v => {
      const id = v.id;
      const name = (v.name || '').toString();
      const delta = Number(v.priceDelta || 0);
      const label = delta === 0 ? name : `${name} (+${delta.toFixed(0)})`;
      const inputId = `manual-var-${idx}-${id}`;
      html += `<div class="form-check form-check-inline mb-0">
        <input class="form-check-input manual-item-variant" type="radio" name="manualVar_${idx}" id="${inputId}" value="${id}">
        <label class="form-check-label small" for="${inputId}">${label}</label>
      </div>`;
    });
    html += '</div>';
  }
  if(adds.length){
    html += '<div><span class="d-block mb-1">الإضافات:</span>';
    adds.forEach(a => {
      const id = a.id;
      const name = (a.name || '').toString();
      const price = Number(a.price || 0);
      const inputId = `manual-add-${idx}-${id}`;
      html += `<div class="form-check form-check-inline mb-0">
        <input class="form-check-input manual-item-addon" type="checkbox" id="${inputId}" value="${id}">
        <label class="form-check-label small" for="${inputId}">${name}${price ? ` (+${price.toFixed(0)})` : ''}</label>
      </div>`;
    });
    html += '</div>';
  }
  container.innerHTML = html;
}

function addManualOrderRow(selectedId, qty){
  const tbody = document.getElementById('manualOrderItemsBody');
  const idx = tbody.querySelectorAll('tr').length;
  tbody.insertAdjacentHTML('beforeend', renderManualOrderRow(idx, manualOrderProducts, selectedId, qty || 1));
  const tr = tbody.querySelector('tr:last-child');
  if(!tr) return;
  tr.setAttribute('data-idx', String(idx));
  tr.querySelector('.btn-remove-manual-item')?.addEventListener('click', function(){
    this.closest('tr')?.remove();
  });
  const prodSelect = tr.querySelector('.manual-item-product');
  if(prodSelect){
    prodSelect.addEventListener('change', function(){
      renderManualOptionsForRow(tr);
    });
  }

  renderManualOptionsForRow(tr);
}

document.getElementById('btnManualOrder').addEventListener('click', async function(){
  if(manualOrderProducts.length === 0) manualOrderProducts = await loadManualOrderProducts();
  document.getElementById('manualCustomerName').value = '';
  document.getElementById('manualCustomerPhone').value = '';
  document.getElementById('manualDeliveryAddress').value = '';
  document.getElementById('manualDeliveryFee').value = '0';
  document.getElementById('manualNotes').value = '';
  document.getElementById('manualOrderItemsBody').innerHTML = '';
  addManualOrderRow(null, 1);
  if(!manualOrderModal) manualOrderModal = new bootstrap.Modal(document.getElementById('modalManualOrder'));
  manualOrderModal.show();
});

document.getElementById('btnAddManualItem').addEventListener('click', function(){
  addManualOrderRow(null, 1);
});

document.getElementById('btnSubmitManualOrder').addEventListener('click', async function(){
  const customerName = (document.getElementById('manualCustomerName').value || '').trim();
  const customerPhone = (document.getElementById('manualCustomerPhone').value || '').trim();
  if(!customerName){ alert('يرجى إدخال اسم الزبون'); return; }
  if(!customerPhone){ alert('يرجى إدخال رقم هاتف الزبون'); return; }
  const rows = document.querySelectorAll('#manualOrderItemsBody tr');
  const items = [];
  for(const tr of rows){
    const productId = parseInt(tr.querySelector('.manual-item-product')?.value, 10);
    const qty = parseInt(tr.querySelector('.manual-item-qty')?.value, 10) || 1;
    if(isNaN(productId) || productId === 0 || qty < 1) continue;
    const varInput = tr.querySelector('.manual-item-variant:checked');
    const addonInputs = tr.querySelectorAll('.manual-item-addon:checked');
    const variantId = varInput ? parseInt(varInput.value, 10) : null;
    const addonIds = Array.from(addonInputs)
      .map(el => parseInt(el.value, 10))
      .filter(v => !isNaN(v));
    let optionsSnapshot = null;
    const optObj = {};
    if(variantId && !isNaN(variantId)) optObj.variantId = variantId;
    if(addonIds.length) optObj.addonIds = addonIds;
    if(Object.keys(optObj).length) optionsSnapshot = JSON.stringify(optObj);
    const item = { productId, quantity: qty };
    if(optionsSnapshot) item.optionsSnapshot = optionsSnapshot;
    items.push(item);
  }
  if(items.length === 0){ alert('يرجى إضافة صنف واحد على الأقل'); return; }
  const payload = {
    customerName,
    customerPhone,
    deliveryAddress: (document.getElementById('manualDeliveryAddress').value || '').trim() || null,
    deliveryFee: parseFloat(document.getElementById('manualDeliveryFee').value) || 0,
    notes: (document.getElementById('manualNotes').value || '').trim() || null,
    items
  };
  this.disabled = true;
  try {
    const res = await fetch('/api/admin/manual-order', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
    const data = await res.json().catch(() => ({}));
    if(!res.ok){
      alert(data.message || 'فشل إنشاء الطلب');
      return;
    }
    manualOrderModal.hide();
    await load();
    if(window.adminToast) window.adminToast('تم إنشاء الطلب', 'تم إضافة الطلب #' + (data.id || '') + ' بنجاح', 'success');
    else alert('تم إنشاء الطلب #' + (data.id || '') + ' بنجاح');
  } catch(e){
    console.error(e);
    alert('حدث خطأ أثناء إنشاء الطلب');
  } finally {
    this.disabled = false;
  }
});

