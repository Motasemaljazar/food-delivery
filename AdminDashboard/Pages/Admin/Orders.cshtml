window.openOrderActionsPopup = function(orderId){
  const o = _ordersList.find(x => x.id === orderId);
  if(!o){ alert('الطلب غير موجود'); return; }
  const hasLatLng = (typeof o.deliveryLat === 'number' && o.deliveryLat && typeof o.deliveryLng === 'number' && o.deliveryLng);
  const canEdit = ![5,6].includes(o.currentStatus);
  const canCancel = canEdit;
  const isPickup = (!hasLatLng); // استلام من الفرع عندما لا يوجد إحداثيات توصيل
  const body = document.getElementById('modalOrderActionsBody');
  body.innerHTML = `
    <div class="d-grid gap-1">
      <button type="button" class="btn btn-sm btn-outline-secondary text-start" data-action="view" data-order-id="${o.id}"><i class="bi bi-eye me-2"></i>عرض الطلب</button>
      <button type="button" class="btn btn-sm btn-outline-secondary text-start" data-action="assign" data-order-id="${o.id}"><i class="bi bi-person-plus me-2"></i>تعيين سائق</button>
      <button type="button" class="btn btn-sm btn-outline-secondary text-start" data-action="edit" data-order-id="${o.id}" ${!canEdit?'disabled':''}><i class="bi bi-pencil me-2"></i>تعديل الطلب</button>
      <button type="button" class="btn btn-sm btn-outline-secondary text-start" data-action="eta" data-order-id="${o.id}"><i class="bi bi-clock me-2"></i>الوقت المتوقع</button>
      <hr class="my-2"/>
      <button type="button" class="btn btn-sm btn-outline-secondary text-start" data-action="print" data-order-id="${o.id}"><i class="bi bi-printer me-2"></i>طباعة</button>
      <button type="button" class="btn btn-sm btn-outline-secondary text-start" data-action="map" data-order-id="${o.id}" data-lat="${o.deliveryLat ?? 0}" data-lng="${o.deliveryLng ?? 0}" ${!hasLatLng?'disabled':''}><i class="bi bi-geo-alt me-2"></i>خريطة</button>
      <button type="button" class="btn btn-sm btn-outline-secondary text-start" data-action="chat" data-order-id="${o.id}" data-customer-id="${o.customerId}"><i class="bi bi-chat-dots me-2"></i>دردشة</button>
      ${o.customerPhone ? `<a class="btn btn-sm btn-outline-secondary text-start" href="tel:${String(o.customerPhone).replace(/"/g,'&quot;')}" role="button"><i class="bi bi-telephone me-2"></i>اتصال</a>` : ''}
      ${isPickup && ![5,6].includes(o.currentStatus) ? `<button type="button" class="btn btn-sm btn-outline-success text-start" data-action="mark-picked-up" data-order-id="${o.id}"><i class="bi bi-bag-check me-2"></i>تم الاستلام من الفرع</button>` : ''}
      <hr class="my-2"/>
      <button type="button" class="btn btn-sm btn-outline-danger text-start" data-action="cancel" data-order-id="${o.id}" ${!canCancel?'disabled':''}><i class="bi bi-x-circle me-2"></i>إلغاء الطلب</button>
      <button type="button" class="btn btn-sm btn-outline-danger text-start" data-action="delete" data-order-id="${o.id}"><i class="bi bi-trash me-2"></i>حذف</button>
    </div>`;
  body.querySelectorAll('[data-action]').forEach(btn=>{
    btn.addEventListener('click', function(){
      const act = this.getAttribute('data-action');
      const id = parseInt(this.getAttribute('data-order-id'),10);
      const order = _ordersList.find(x=>x.id===id);
      if(!order) return;
      if(this.disabled) return;
      if(_orderActionsModal) _orderActionsModal.hide();
      if(act==='view') openViewOrder(id);
      else if(act==='assign') openAssign(id, order.driverId ?? null);
      else if(act==='edit') openEditOrder(id);
      else if(act==='eta') openEta(id, order.prepEtaMinutes ?? null, order.deliveryEtaMinutes ?? null);
      else if(act==='print') openPrint(id);
      else if(act==='map') openMap(order.deliveryLat ?? 0, order.deliveryLng ?? 0);
      else if(act==='chat') openChat(order.customerId);
      else if(act==='cancel') cancelOrder(id);
      else if(act==='delete') deleteOrder(id);
      else if(act==='mark-picked-up') markPickupDelivered(id);
    });
  });
  if(!_orderActionsModal) _orderActionsModal = new bootstrap.Modal(document.getElementById('modalOrderActions'));
  _orderActionsModal.show();
};

