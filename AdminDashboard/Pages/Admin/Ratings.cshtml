@page
@model AdminDashboard.Pages.Admin.AdminPageModel

<div class="d-flex align-items-center justify-content-between mb-3">
  <h2 class="h5 m-0">التقييمات</h2>
  <div class="d-flex gap-2 align-items-center">
    <input type="date" class="form-control form-control-sm" id="fromDate" style="width: 170px" />
    <input type="date" class="form-control form-control-sm" id="toDate" style="width: 170px" />
    <input type="text" class="form-control form-control-sm" id="q" placeholder="بحث: رقم الطلب/اسم/هاتف" style="width: 220px" />
    <button class="btn btn-outline-primary btn-sm" id="btnApply">تصفية</button>
    <button class="btn btn-outline-secondary btn-sm" id="btnRefresh">تحديث</button>
  </div>
</div>

<div class="card p-3 rounded-4">
  <div class="mb-2 small text-muted" id="avg"></div>
  <div class="table-responsive">
    <table class="table table-sm align-middle">
      <thead>
        <tr>
          <th>الطلب</th>
          <th>الزبون</th>
          <th>تقييم المطعم</th>
          <th>تقييم السائق</th>
          <th>التعليقات</th>
          <th>التاريخ</th>
        </tr>
      </thead>
      <tbody id="rows">
        <tr><td colspan="6" class="text-muted">جاري التحميل...</td></tr>
      </tbody>
    </table>
  </div>
</div>

@section Scripts {
<script>
const rows = document.getElementById('rows');
const avg = document.getElementById('avg');
const fromDate = document.getElementById('fromDate');
const toDate = document.getElementById('toDate');
const q = document.getElementById('q');
const btnApply = document.getElementById('btnApply');
const fmtStars = (s)=> (s && s>=1) ? '★'.repeat(s) + '☆'.repeat(5-s) : '—';
const esc = (s)=> (s||'').replaceAll('&','&amp;').replaceAll('<','&lt;').replaceAll('>','&gt;');

async function load(){
  rows.innerHTML = '<tr><td colspan="6" class="text-muted">جاري التحميل...</td></tr>';
  const qs = new URLSearchParams();
  if(fromDate.value){ qs.set('fromUtc', fromDate.value + 'T00:00:00Z'); }
  if(toDate.value){ 
    // toUtc is exclusive; add one day
    const d = new Date(toDate.value + 'T00:00:00Z');
    d.setUTCDate(d.getUTCDate()+1);
    qs.set('toUtc', d.toISOString());
  }
    if(q.value && q.value.trim()){ qs.set('q', q.value.trim()); }
  const res = await fetch('/api/admin/ratings' + (qs.toString()?('?'+qs.toString()):''));
  if(!res.ok){ rows.innerHTML = '<tr><td colspan="6" class="text-danger">فشل تحميل التقييمات</td></tr>'; return; }
  const j = await res.json();
  const items = j.items || [];
  const aR = j.averages?.restaurant;
  const aD = j.averages?.driver;
  const cnt = j.count ?? items.length;
  avg.innerText = `متوسط تقييم المطعم: ${aR ?? '—'} | متوسط تقييم السائق: ${aD ?? '—'} | عدد التقييمات: ${cnt}`;
  if(items.length===0){ rows.innerHTML = '<tr><td colspan="6" class="text-muted">لا يوجد تقييمات بعد</td></tr>'; return; }

  rows.innerHTML = items.map(x=>{
    const cust = x.customer?.name ? `${esc(x.customer.name)} (${esc(x.customer.phone||'')})` : '—';
    const restC = x.restaurantComment ? esc(x.restaurantComment) : '';
    const drvC = x.driverComment ? esc(x.driverComment) : '';
    const comments = [restC ? `مطعم: ${restC}` : '', drvC ? `سائق: ${drvC}` : ''].filter(Boolean).join('<br/>') || '—';
    const date = x.createdAtUtc ? new Date(x.createdAtUtc).toLocaleString() : '';
    return `<tr>
      <td><a href="/Admin/Orders?orderId=${x.orderId}" class="text-decoration-none">#${x.orderId}</a></td>
      <td>${cust}</td>
      <td>${fmtStars(x.restaurantRate)}</td>
      <td>${fmtStars(x.driverRate)}</td>
      <td style="max-width:360px; white-space:normal;">${comments}</td>
      <td class="text-muted small">${date}</td>
    </tr>`;
  }).join('');
}

document.getElementById('btnRefresh').addEventListener('click', load);
btnApply.addEventListener('click', load);

load();

// Realtime refresh when a new rating is created
(function(){
  if(!window.signalR){ return; }
  try{
    const conn = new signalR.HubConnectionBuilder().withUrl('/hubs/notify').withAutomaticReconnect().build();
    conn.on('rating_added', ()=>{ load(); });
    conn.start().catch(()=>{});
  }catch(e){}
})();

</script>
}
