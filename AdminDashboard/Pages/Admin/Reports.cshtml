      </div>
    </div>
    <div class="report-print-section card mt-3">
      <div class="card-body">
        <h6 class="mb-3">تفاصيل الأيام</h6>
        <div class="table-responsive">
          <table class="table table-striped table-report-print">
            <thead><tr><th>التاريخ</th><th>عدد الطلبات</th><th>الإيراد</th></tr></thead>
