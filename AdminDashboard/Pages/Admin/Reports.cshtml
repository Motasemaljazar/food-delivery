      <div class="card-body">
        <h6 class="mb-3">مخطط الشهر</h6>
        <div class="row g-3">
          <div class="col-lg-6">
            <div class="border rounded p-2">
              <div class="text-muted small mb-2">عدد الطلبات يوميًا</div>
              <canvas id="monthOrdersChart" height="140"></canvas>
            </div>
          </div>
          <div class="col-lg-6">
            <div class="border rounded p-2">
              <div class="text-muted small mb-2">الإيراد يوميًا</div>
              <canvas id="monthSalesChart" height="140"></canvas>
            </div>
          </div>
