    <div class="report-print-section card mt-3">
      <div class="card-body">
        <h6 class="mb-3">أفضل الأصناف (الشهر)</h6>
        <div class="table-responsive">
          <table class="table table-striped table-report-print">
            <thead><tr><th>الصنف</th><th>الكمية</th><th>الإيراد</th></tr></thead>
            <tbody id="monthTopProducts"></tbody>
          </table>
        </div>
      </div>
    </div>
    <div class="report-print-section card mt-3">
      <div class="card-body">
        <h6 class="mb-3">أفضل السائقين (الشهر)</h6>
        <div class="table-responsive">
          <table class="table table-striped table-report-print">
            <thead><tr><th>السائق</th><th>الطلبات</th><th>المجموع</th><th>المسافة (كم)</th><th>متوسط زمن التوصيل (د)</th></tr></thead>
            <tbody id="monthTopDrivers"></tbody>
          </table>
        </div>
      </div>
