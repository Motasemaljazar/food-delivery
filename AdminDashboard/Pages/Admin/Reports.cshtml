@page
@model AdminDashboard.Pages.Admin.AdminPageModel
@{
    ViewData["Title"] = "التقارير";
}

<h3 class="mb-4 print-hide">لوحة التقارير والإحصائيات</h3>

<!-- ترويسة الطباعة فقط (تظهر في الطباعة فوق كل تقرير) -->
<div id="reportPrintHeader" class="report-print-header d-none border-bottom border-2 pb-2 mb-3"></div>

<div class="d-flex flex-wrap gap-2 align-items-center mb-4 print-hide">
  <button type="button" class="btn btn-primary btn-sm shadow-sm" onclick="printReportByType('today')">
    <i class="bi bi-printer me-1"></i> طباعة تقرير اليوم
  </button>
  <button type="button" class="btn btn-outline-primary btn-sm shadow-sm" onclick="printReportByType('week')">
    <i class="bi bi-printer me-1"></i> طباعة تقرير الأسبوع
  </button>
  <button type="button" class="btn btn-outline-primary btn-sm shadow-sm" onclick="printReportByType('month')">
    <i class="bi bi-printer me-1"></i> طباعة تقرير الشهر
  </button>
  <span class="badge bg-light text-dark border">كل جدول في صفحة منفصلة • A4</span>
</div>

<style>
  /* Print (A4) */
  @@page { size: A4; margin: 14mm; }

  /* ترويسة الطباعة: تظهر فقط عند الطباعة */
  .report-print-header { font-size: 16px; font-weight: 700; }
  @@media screen {
    .report-print-header.d-none { display: none !important; }
  }
  @@media print {
    .report-print-header { display: block !important; }
  }

  /* جدول بأسلوب شبيه بالإكسل عند الطباعة */
  @@media print {
    .report-print-section { page-break-after: always; }
    .report-print-section:last-child { page-break-after: auto; }
    .table-report-print,
    .table-report-print th,
    .table-report-print td {
      border: 1px solid #333 !important;
      padding: 6px 10px !important;
      font-size: 11px !important;
    }
    .table-report-print thead th {
      background: #e8e8e8 !important;
      font-weight: 700 !important;
    }
    .table-report-print tbody tr:nth-child(even) { background: #f8f8f8 !important; }
    /* إخفاء المخططات عند طباعة تقرير الأسبوع أو الشهر */
    body.print-report-week .report-print-hide-charts,
    body.print-report-month .report-print-hide-charts { display: none !important; }
  }

  @@media print {
    .print-hide, .nav, .nav-pills, #reportTabs { display: none !important; }
    body.print-report-today .tab-pane#pane-week,
    body.print-report-today .tab-pane#pane-month { display: none !important; }
    body.print-report-week .tab-pane#pane-today,
    body.print-report-week .tab-pane#pane-month { display: none !important; }
    body.print-report-month .tab-pane#pane-today,
    body.print-report-month .tab-pane#pane-week { display: none !important; }
    .tab-content > .tab-pane { display: block !important; opacity: 1 !important; }
    .tab-pane.fade { opacity: 1 !important; }
    body { font-size: 12px; }
    h3 { margin-bottom: 8px !important; }
    h5, h6 { margin-top: 12px !important; margin-bottom: 8px !important; }
    .card { break-inside: avoid; page-break-inside: avoid; border: 1px solid #ccc !important; }
    table { break-inside: avoid; page-break-inside: avoid; }
    .table-responsive { overflow: visible !important; }
  }
</style>

<ul class="nav nav-pills mb-3" id="reportTabs" role="tablist">
  <li class="nav-item" role="presentation">
    <button class="nav-link active" id="tab-today" data-bs-toggle="pill" data-bs-target="#pane-today" type="button" role="tab">اليوم</button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="tab-week" data-bs-toggle="pill" data-bs-target="#pane-week" type="button" role="tab">هذا الأسبوع</button>
  </li>
  <li class="nav-item" role="presentation">
    <button class="nav-link" id="tab-month" data-bs-toggle="pill" data-bs-target="#pane-month" type="button" role="tab">هذا الشهر</button>
  </li>
</ul>

<div class="tab-content">
  <div class="tab-pane fade show active" id="pane-today" role="tabpanel">
    <div class="report-print-section">
      <h5 class="mb-3">ملخص اليوم</h5>
      <div class="row g-3" id="cards"></div>
    </div>
    <div class="report-print-section card mt-3">
      <div class="card-body">
        <h5 class="mb-3">أفضل المنتجات</h5>
        <div class="table-responsive">
          <table class="table table-striped table-report-print">
            <thead><tr><th>المنتج</th><th>الكمية</th></tr></thead>
            <tbody id="topProducts"></tbody>
          </table>
        </div>
      </div>
    </div>
    <div class="report-print-section card mt-3">
      <div class="card-body">
        <h5 class="mb-3">مبيعات الأصناف اليوم (تم التسليم فقط)</h5>
        <div class="table-responsive">
          <table class="table table-striped table-report-print">
            <thead><tr><th>المنتج</th><th>الكمية</th><th>الإيراد</th></tr></thead>
            <tbody id="productsDaily"></tbody>
          </table>
        </div>
      </div>
    </div>
    <div class="report-print-section card mt-3">
      <div class="card-body">
        <h5 class="mb-3">تقارير السائقين اليوم (تم التسليم فقط)</h5>
        <div class="table-responsive">
          <table class="table table-striped table-report-print">
            <thead><tr><th>السائق</th><th>الطلبات المسلمة</th><th>المجموع</th><th>المسافة التقديرية (كم)</th></tr></thead>
            <tbody id="driversDaily"></tbody>
          </table>
        </div>
      </div>
    </div>
    <div class="report-print-section card mt-3">
      <div class="card-body">
        <h5 class="mb-3">أفضل السائقين</h5>
        <div class="table-responsive">
          <table class="table table-striped table-report-print">
            <thead><tr><th>السائق</th><th>الطلبات</th><th>المجموع</th><th>متوسط زمن التوصيل (د)</th></tr></thead>
            <tbody id="topDrivers"></tbody>
          </table>
        </div>
      </div>
    </div>
    <div class="report-print-section card mt-3">
      <div class="card-body">
        <h5 class="mb-3">أفضل الأصناف</h5>
        <div class="table-responsive">
          <table class="table table-striped table-report-print">
            <thead><tr><th>الصنف</th><th>الكمية</th><th>الإيراد</th></tr></thead>
            <tbody id="topProducts2"></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <div class="tab-pane fade" id="pane-week" role="tabpanel">
    <div class="report-print-section">
      <h5 class="mb-3">ملخص الأسبوع (آخر 7 أيام)</h5>
      <div class="row g-3" id="weekCards"></div>
    </div>
    <div class="report-print-section card mt-3 report-print-hide-charts">
      <div class="card-body">
        <h6 class="mb-3">مخطط الأسبوع</h6>
        <div class="row g-3">
          <div class="col-lg-6">
            <div class="border rounded p-2">
