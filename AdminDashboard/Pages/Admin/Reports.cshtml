@section Scripts {
<script>

// ---- Printing (A4) ----
let __reportsPrevActiveTabId = null;
let __restaurantName = 'مطعم توب شيف';
let __printReportType = null;

function __showAllReportPanesForPrint(){
  const activeBtn = document.querySelector('#reportTabs .nav-link.active');
  __reportsPrevActiveTabId = activeBtn ? activeBtn.id : null;

  if (__printReportType) {
    document.body.classList.add('print-report-' + __printReportType);
  } else {
    document.querySelectorAll('.tab-content > .tab-pane').forEach(p=>{
      p.classList.add('show','active');
      p.style.display = 'block';
      p.style.opacity = '1';
    });
  }

  const c = window.__reportsCharts;
  if(c?.week){
    _drawChart('weekOrdersChart', c.week.labels, c.week.orders, { type:'bar', barColor:'#FFB300' });
    _drawChart('weekSalesChart', c.week.labels, c.week.sales, { type:'line', color:'#FB8C00' });
  }
  if(c?.month){
    _drawChart('monthOrdersChart', c.month.labels, c.month.orders, { type:'bar', barColor:'#FFB300' });
    _drawChart('monthSalesChart', c.month.labels, c.month.sales, { type:'line', color:'#FB8C00' });
  }
}

function __restoreReportTabsAfterPrint(){
  __printReportType = null;
  document.body.classList.remove('print-report-today', 'print-report-week', 'print-report-month');
  document.querySelectorAll('.tab-content > .tab-pane').forEach(p=>{
    p.style.removeProperty('display');
    p.style.removeProperty('opacity');
    p.classList.remove('show','active');
  });
  if(__reportsPrevActiveTabId){
    const btn = document.getElementById(__reportsPrevActiveTabId);
    if(btn){ try{ btn.click(); }catch(e){} }
  } else {
    const btn = document.getElementById('tab-today');
    if(btn){ try{ btn.click(); }catch(e){} }
  }
}

function _reportDateRange(type){
  const d = new Date();
  if (type === 'today') return d.toLocaleDateString('ar-SA');
  if (type === 'week') {
    const end = new Date(d);
    const start = new Date(d); start.setDate(start.getDate() - 6);
    return 'من ' + start.toLocaleDateString('ar-SA') + ' إلى ' + end.toLocaleDateString('ar-SA');
  }
  if (type === 'month') return 'شهر ' + d.toLocaleDateString('ar-SA', { month: 'long', year: 'numeric' });
  return '';
}

function printReportByType(type){
  __printReportType = type;
  const title = type === 'today' ? 'تقرير اليوم' : type === 'week' ? 'تقرير الأسبوع' : 'تقرير الشهر';
  const dateStr = _reportDateRange(type);
  const el = document.getElementById('reportPrintHeader');
  if (el) el.innerHTML = title + ' — ' + __restaurantName + ' — ' + dateStr;
  document.body.classList.add('print-report-' + type);
  requestAnimationFrame(()=>requestAnimationFrame(()=>window.print()));
}

window.addEventListener('beforeprint', __showAllReportPanesForPrint);
window.addEventListener('afterprint', __restoreReportTabsAfterPrint);

function _fmtNumber(n){
  try{
    if(n==null || isNaN(n)) return 0;
    const v = Number(n);
    return Math.floor(v);
  }catch(e){ return n ?? 0; }
}

function _drawChart(canvasId, labels, values, opts){
  const canvas = document.getElementById(canvasId);
  if(!canvas) return;
  const ctx = canvas.getContext('2d');
  const w = (canvas.parentElement && canvas.parentElement.clientWidth ? canvas.parentElement.clientWidth : (canvas.clientWidth || canvas.width || 420));
  const h = canvas.height || 140;
  canvas.width = w * (window.devicePixelRatio || 1);
  canvas.height = h * (window.devicePixelRatio || 1);
  ctx.scale((window.devicePixelRatio || 1), (window.devicePixelRatio || 1));
  ctx.clearRect(0,0,w,h);

  const padding = 28;
  const max = Math.max(1, ...values.map(v=>Number(v)||0));
  const min = 0;

  // axes
  ctx.globalAlpha = 0.25;
  ctx.beginPath();
  ctx.moveTo(padding, 8);
  ctx.lineTo(padding, h - padding);
  ctx.lineTo(w - 8, h - padding);
  ctx.stroke();
  ctx.globalAlpha = 1;

  const plotW = (w - padding - 10);
  const plotH = (h - padding - 10);

  // grid lines
  ctx.globalAlpha = 0.18;
  const grid = 4;
  for(let i=1;i<=grid;i++){
    const y = 10 + (plotH * i / grid);
    ctx.beginPath();
    ctx.moveTo(padding, y);
    ctx.lineTo(w-8, y);
    ctx.stroke();
  }
  ctx.globalAlpha = 1;

  const type = (opts && opts.type) ? opts.type : 'line';
  const color = (opts && opts.color) ? opts.color : '#E53935'; // red-ish
  const barColor = (opts && opts.barColor) ? opts.barColor : '#FFB300'; // amber-ish

  if(values.length === 0){
    ctx.globalAlpha = 0.65;
    ctx.fillText('لا توجد بيانات', padding + 10, h/2);
    ctx.globalAlpha = 1;
    return;
  }

  const xStep = values.length <= 1 ? plotW : (plotW / (values.length - 1));

  if(type === 'bar'){
    const barW = Math.max(6, Math.min(24, xStep * 0.55));
    for(let i=0;i<values.length;i++){
      const v = Number(values[i])||0;
      const x = padding + i * xStep;
      const y = 10 + plotH * (1 - (v-min)/(max-min));
      const bh = (h - padding) - y;
      ctx.globalAlpha = 0.9;
      ctx.fillStyle = barColor;
      ctx.fillRect(x - barW/2, y, barW, bh);
      ctx.globalAlpha = 1;
    }
  }else{
    // line
    ctx.lineWidth = 2;
    ctx.strokeStyle = color;
    ctx.beginPath();
    for(let i=0;i<values.length;i++){
      const v = Number(values[i])||0;
      const x = padding + i * xStep;
      const y = 10 + plotH * (1 - (v-min)/(max-min));
      if(i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);
    }
    ctx.stroke();

    // points
    ctx.fillStyle = color;
    for(let i=0;i<values.length;i++){
      const v = Number(values[i])||0;
      const x = padding + i * xStep;
      const y = 10 + plotH * (1 - (v-min)/(max-min));
      ctx.beginPath();
      ctx.arc(x,y,3,0,Math.PI*2);
      ctx.fill();
    }
  }

  // x labels (sparse)
  ctx.globalAlpha = 0.8;
  ctx.font = '11px sans-serif';
  const every = Math.ceil(labels.length / 6);
  for(let i=0;i<labels.length;i++){
    if(i % every !== 0 && i !== labels.length-1) continue;
    const x = padding + i * xStep;
    const t = labels[i] ?? '';
    ctx.fillText(t, Math.min(w-40, Math.max(0, x-10)), h - 10);
  }
  ctx.globalAlpha = 1;
}

async function load(){
  const res = await fetch('/api/admin/reports/summary');
  const j = await res.json();
  if (j.restaurantName) __restaurantName = j.restaurantName;
  const cards = document.getElementById('cards');
  cards.innerHTML = `
    <div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted">مبيعات اليوم</div><div class="fs-4">${_fmtNumber(j.salesToday)}</div></div></div></div>
    <div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted">عدد الطلبات</div><div class="fs-4">${j.ordersCount}</div></div></div></div>
    <div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted">متوسط وقت التحضير (د)</div><div class="fs-4">${j.avgPrepEtaMinutes ?? '-'}</div></div></div></div>
  `;
  const tbody = document.getElementById('topProducts');
  tbody.innerHTML = (j.topProducts||[]).map(p=>`<tr><td>${p.name}</td><td>${p.qty}</td></tr>`).join('') || `<tr><td colspan="2" class="text-muted">لا توجد بيانات</td></tr>`;

  // Products daily (delivered)
  const pd = await (await fetch('/api/admin/reports/products-daily')).json();
  document.getElementById('productsDaily').innerHTML = (pd||[]).map(r=>`<tr><td>${r.name}</td><td>${r.qty}</td><td>${_fmtNumber(r.revenue ?? 0)}</td></tr>`).join('') || `<tr><td colspan="3" class="text-muted">لا توجد بيانات</td></tr>`;

  // Drivers daily (delivered)
  const dd = await (await fetch('/api/admin/reports/drivers-daily')).json();
  document.getElementById('driversDaily').innerHTML = (dd||[]).map(r=>`<tr><td>${r.driverName}</td><td>${r.deliveredCount}</td><td>${_fmtNumber(r.totalAmount ?? 0)}</td><td>${_fmtNumber(r.totalDistanceKm ?? 0)}</td></tr>`).join('') || `<tr><td colspan="4" class="text-muted">لا توجد بيانات</td></tr>`;

  // Tops
  const tops = await (await fetch('/api/admin/reports/top')).json();
  document.getElementById('topDrivers').innerHTML = (tops.topDrivers||[]).map(r=>`<tr><td>${r.driverName}</td><td>${r.deliveredCount}</td><td>${_fmtNumber(r.totalAmount ?? 0)}</td><td>${r.avgDeliveryMinutes==null ? '-' : _fmtNumber(r.avgDeliveryMinutes)}</td></tr>`).join('') || `<tr><td colspan="4" class="text-muted">لا توجد بيانات</td></tr>`;
  document.getElementById('topProducts2').innerHTML = (tops.topProducts||[]).map(r=>`<tr><td>${r.name}</td><td>${r.qty}</td><td>${_fmtNumber(r.revenue ?? 0)}</td></tr>`).join('') || `<tr><td colspan="3" class="text-muted">لا توجد بيانات</td></tr>`;


  // Weekly
  const w = await (await fetch('/api/admin/reports/weekly-summary')).json();
  if (w.restaurantName) __restaurantName = w.restaurantName;
  document.getElementById('weekCards').innerHTML = `
    <div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted">مبيعات الأسبوع</div><div class="fs-4">${_fmtNumber(w.sales ?? 0)}</div></div></div></div>
    <div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted">عدد الطلبات</div><div class="fs-4">${w.ordersCount ?? 0}</div></div></div></div>
    <div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted">متوسط زمن التوصيل (د)</div><div class="fs-4">${w.avgDeliveryEtaMinutes==null ? '-' : (w.avgDeliveryEtaMinutes.toFixed ? w.avgDeliveryEtaMinutes.toFixed(0) : w.avgDeliveryEtaMinutes)}</div></div></div></div>
  `;
  const wDaily = (w.daily||[]).map(r=>{
    const d = new Date(r.dateUtc);
    return `<tr><td>${d.toLocaleDateString('ar')}</td><td>${r.ordersCount}</td><td>${_fmtNumber(r.sales ?? 0)}</td></tr>`;
  }).join('') || `<tr><td colspan="3" class="text-muted">لا توجد بيانات</td></tr>`;
  document.getElementById('weekDaily').innerHTML = wDaily;
  const wLabels = (w.daily||[]).map(r=>{ const d=new Date(r.dateUtc); return d.toLocaleDateString('ar', { month:'numeric', day:'numeric' }); });
  const wOrdersSeries = (w.daily||[]).map(r=>Number(r.ordersCount)||0);
  const wSalesSeries = (w.daily||[]).map(r=>Number(r.sales)||0);
  _drawChart('weekOrdersChart', wLabels, wOrdersSeries, { type:'bar', barColor:'#FFB300' });
  _drawChart('weekSalesChart', wLabels, wSalesSeries, { type:'line', color:'#FB8C00' });
  document.getElementById('weekTopProducts').innerHTML = (w.topProducts||[]).map(r=>`<tr><td>${r.name}</td><td>${r.qty}</td><td>${_fmtNumber(r.revenue ?? 0)}</td></tr>`).join('') || `<tr><td colspan="3" class="text-muted">لا توجد بيانات</td></tr>`;
  document.getElementById('weekTopDrivers').innerHTML = (w.topDrivers||[]).map(r=>`<tr><td>${r.driverName}</td><td>${r.deliveredCount}</td><td>${_fmtNumber(r.totalAmount ?? 0)}</td><td>${_fmtNumber(r.totalDistanceKm ?? 0)}</td><td>${r.avgDeliveryMinutes==null ? '-' : _fmtNumber(r.avgDeliveryMinutes)}</td></tr>`).join('') || `<tr><td colspan="5" class="text-muted">لا توجد بيانات</td></tr>`;

  // Monthly
  const m = await (await fetch('/api/admin/reports/monthly-summary')).json();
  if (m.restaurantName) __restaurantName = m.restaurantName;
  document.getElementById('monthCards').innerHTML = `
    <div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted">مبيعات الشهر</div><div class="fs-4">${_fmtNumber(m.sales ?? 0)}</div></div></div></div>
    <div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted">عدد الطلبات</div><div class="fs-4">${m.ordersCount ?? 0}</div></div></div></div>
    <div class="col-md-4"><div class="card"><div class="card-body"><div class="text-muted">متوسط زمن التوصيل (د)</div><div class="fs-4">${m.avgDeliveryEtaMinutes==null ? '-' : (m.avgDeliveryEtaMinutes.toFixed ? m.avgDeliveryEtaMinutes.toFixed(0) : m.avgDeliveryEtaMinutes)}</div></div></div></div>
  `;
  const mDaily = (m.daily||[]).map(r=>{
    const d = new Date(r.dateUtc);
    return `<tr><td>${d.toLocaleDateString('ar')}</td><td>${r.ordersCount}</td><td>${_fmtNumber(r.sales ?? 0)}</td></tr>`;
  }).join('') || `<tr><td colspan="3" class="text-muted">لا توجد بيانات</td></tr>`;
  document.getElementById('monthDaily').innerHTML = mDaily;
  const mLabels = (m.daily||[]).map(r=>{ const d=new Date(r.dateUtc); return d.toLocaleDateString('ar', { month:'numeric', day:'numeric' }); });
  const mOrdersSeries = (m.daily||[]).map(r=>Number(r.ordersCount)||0);
  const mSalesSeries = (m.daily||[]).map(r=>Number(r.sales)||0);
  _drawChart('monthOrdersChart', mLabels, mOrdersSeries, { type:'bar', barColor:'#FFB300' });
  _drawChart('monthSalesChart', mLabels, mSalesSeries, { type:'line', color:'#FB8C00' });
  document.getElementById('monthTopProducts').innerHTML = (m.topProducts||[]).map(r=>`<tr><td>${r.name}</td><td>${r.qty}</td><td>${_fmtNumber(r.revenue ?? 0)}</td></tr>`).join('') || `<tr><td colspan="3" class="text-muted">لا توجد بيانات</td></tr>`;
  document.getElementById('monthTopDrivers').innerHTML = (m.topDrivers||[]).map(r=>`<tr><td>${r.driverName}</td><td>${r.deliveredCount}</td><td>${_fmtNumber(r.totalAmount ?? 0)}</td><td>${_fmtNumber(r.totalDistanceKm ?? 0)}</td><td>${r.avgDeliveryMinutes==null ? '-' : _fmtNumber(r.avgDeliveryMinutes)}</td></tr>`).join('') || `<tr><td colspan="5" class="text-muted">لا توجد بيانات</td></tr>`;

  // Re-draw charts when switching tabs (because canvas in hidden tab may have width 0)
  window.__reportsCharts = {
    week: { labels: wLabels, orders: wOrdersSeries, sales: wSalesSeries },
    month: { labels: mLabels, orders: mOrdersSeries, sales: mSalesSeries }
  };
  document.querySelectorAll('button[data-bs-toggle="pill"]').forEach(btn=>{
    btn.addEventListener('shown.bs.tab', function(){
      const c = window.__reportsCharts;
      if(!c) return;
      if(this.id === 'tab-week'){
        _drawChart('weekOrdersChart', c.week.labels, c.week.orders, { type:'bar', barColor:'#FFB300' });
        _drawChart('weekSalesChart', c.week.labels, c.week.sales, { type:'line', color:'#FB8C00' });
      }
      if(this.id === 'tab-month'){
        _drawChart('monthOrdersChart', c.month.labels, c.month.orders, { type:'bar', barColor:'#FFB300' });
        _drawChart('monthSalesChart', c.month.labels, c.month.sales, { type:'line', color:'#FB8C00' });
      }
    });
  });

}
load();
</script>
}
